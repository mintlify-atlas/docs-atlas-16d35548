  "keyFeatures": [
    "Bare-metal no_std HAL for all Espressif ESP32 chip families (ESP32, C, H, S series)",
    "Blocking and async peripheral driver APIs via embedded-hal traits",
    "Peripheral singleton ownership model preventing hardware conflicts",
    "DMA support for high-throughput data transfers",
    "Support for both RISC-V (ESP32-C/H series) and Xtensa (ESP32/S series) architectures",
    "Stable and unstable API tiers with clear semver guarantees",
    "embassy-based async runtime integration",
    "Comprehensive peripheral coverage: GPIO, SPI, I2C, UART, RMT, I2S, LEDC, timers, crypto accelerators, and more"
  ],
  "publicApiSurface": [
    "esp_hal::init(Config) -> Peripherals",
    "esp_hal::gpio::{Input, Output, Flex, OutputOpenDrain}",
    "esp_hal::spi::master::Spi",
